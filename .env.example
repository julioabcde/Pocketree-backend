# Database Configuration
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/pocketree

# Security Configuration
# Generate a secure secret key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT Token Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Reports Cache Configuration
REPORTS_CACHE_ENABLED=false
REDIS_URL=redis://localhost:6379/0
REPORTS_CACHE_TTL_OVERVIEW=300
REPORTS_CACHE_TTL_TREND=600
REPORTS_CACHE_TTL_BREAKDOWN=600
REPORTS_CACHE_TTL_TOP_TRANSACTIONS=600
REPORTS_CACHE_TTL_PERIOD_COMPARISON=600

# Gemini (Google Generative AI) Configuration
# Get an API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
